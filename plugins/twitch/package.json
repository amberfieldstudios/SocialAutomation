{
  "name": "@social/plugin-twitch",
  "version": "0.1.0",
  "private": true,
  "description": "Twitch Helix connector plugin implementing the PlatformConnector contract via the official Twitch API only.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "socialPlugin": {
    "platform": "twitch",
    "contractVersion": "1.1.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@social/core": "workspace:*"
  },
  "devDependencies": {
    "@social/conformance": "workspace:*",
    "@social/logging": "workspace:*",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  }
}
