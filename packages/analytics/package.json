{
  "name": "@social/analytics",
  "version": "0.1.0",
  "private": true,
  "description": "Analytics collection (per-post connector.getAnalytics -> normalized snapshots) and campaign aggregation, backed by @social/db's analytics_snapshots repo.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@social/core": "workspace:*",
    "@social/db": "workspace:*",
    "@social/logging": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  }
}
