{
  "name": "@social/db",
  "version": "0.1.0",
  "private": true,
  "description": "Database schema, migrations, driver abstraction (SQLite dev / Postgres prod) and repository implementations of the @social/auth and @social/queue storage ports.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@social/core": "workspace:*",
    "@social/logging": "workspace:*"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@social/auth": "workspace:*",
    "@social/queue": "workspace:*",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  }
}
