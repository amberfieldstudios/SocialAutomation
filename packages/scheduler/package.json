{
  "name": "@social/scheduler",
  "version": "0.1.0",
  "private": true,
  "description": "Scheduling engine: immediate / one-shot scheduled / recurring (cron or RRULE) campaign publishing with IANA-timezone-aware local->UTC conversion, plus the ScheduleMaterializer that turns due occurrences into idempotently-submitted campaigns.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@social/core": "workspace:*",
    "@social/db": "workspace:*",
    "@social/logging": "workspace:*",
    "cron-parser": "^5.6.1",
    "luxon": "^3.7.2",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  }
}
