{
  "name": "@social/ui",
  "version": "0.1.0",
  "private": true,
  "description": "React + Vite dashboard consuming @social/api: connected-accounts manager, campaign composer with live per-platform previews (MockProvider + validatePost), queue/schedule views, publish history, and campaign analytics. Accessible and keyboard-navigable.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
