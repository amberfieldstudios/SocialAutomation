{
  "name": "@social/ai",
  "version": "0.1.0",
  "private": true,
  "description": "Content generation: from one content brief, produce per-platform post variants (tone/length tuned, hashtags, emojis, CTAs, titles, SEO) via a swappable ContentProvider (Claude API in production, a deterministic mock in tests).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@social/core": "workspace:*",
    "@social/logging": "workspace:*",
    "@anthropic-ai/sdk": "^0.65.0",
    "openai": "^6.45.0"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.14.1"
  },
  "devDependencies": {
    "@social/plugin-bluesky": "workspace:*",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  }
}
