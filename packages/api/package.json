{
  "name": "@social/api",
  "version": "0.1.0",
  "private": true,
  "description": "Thin REST/BFF over the core pipeline services (accounts, campaign compose/submit, queue+schedule, publish history, campaign analytics) for the @social/ui dashboard. Uses @social/pipeline's buildPipeline() so requests hit the real AccountManager/CampaignService/PublishService/queue/analytics stack against a SQLite dev DB.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite-node --watch src/dev.ts",
    "start": "vite-node src/prod.ts",
    "seed": "vite-node src/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@social/ai": "workspace:*",
    "@social/analytics": "workspace:*",
    "@social/auth": "workspace:*",
    "@social/core": "workspace:*",
    "@social/db": "workspace:*",
    "@social/logging": "workspace:*",
    "@social/pipeline": "workspace:*",
    "@social/queue": "workspace:*",
    "@social/scheduler": "workspace:*",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.5.0",
    "vite-node": "^2.1.9",
    "vitest": "^2.0.5"
  }
}
